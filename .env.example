TELEGRAM_BOT_TOKEN=        # from @BotFather
TELEGRAM_CHAT_ID=          # run /chatid in the bot to get your personal chat ID
OPENAI_API_KEY=            # openai.com — Whisper transcription only
OPENROUTER_API_KEY=        # openrouter.ai — all LLM calls
OPENROUTER_MODEL=openai/gpt-4o-mini
NOTION_API_KEY=            # notion.so/my-integrations
NOTION_DATABASE_ID=        # hex ID from the Tasks database URL
TZ=Europe/Sofia            # your timezone (for cron scheduling)
NTFY_TOPIC=                # ntfy.sh topic name for iPhone push (e.g. kiril-tasks-xyz123)
